      <column caption='LOB-Claim Type' datatype='string' name='[Blues-LOB (copy)_1002332437970407424]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_843017591817953280]+&quot;, &quot;+[claim_type_desc_oi]' />
      </column>
      <column caption='Blues-Claim Type' datatype='string' name='[Blues-LOB (copy)_1002332437970640897]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='(IF [blues_indicator]=&apos;Y&apos; then &apos;Blues&apos; ELSE &apos;Non-Blues&apos; END)+&quot;, &quot;+[claim_type_desc_oi]' />
      </column>
      <column caption='index' datatype='integer' name='[Calculation_1053842317925126144]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='index()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Customer Filter - PGA' datatype='boolean' name='[Calculation_1192891019775012865]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[federated.1imvvin1bxbutr11t1h3i12baoiy].[#Super Payer Shorts (copy)_1215127508940943366] &gt;= 1' />
      </column>
      <column caption='Customer Filter - Select View ' datatype='boolean' name='[Calculation_1192891019775565827]' role='measure' type='nominal'>
        <calculation class='tableau' formula='if [Parameters].[Parameter 2] = &quot;Policy Gap Analysis&quot; then [Calculation_1192891019775012865]&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &quot;Integrated Opportunity with Benchmarks&quot; then [Customer Filter - PGA (copy)_1192891019775422466]&#13;&#10;END' />
      </column>
      <column caption='Date for footer' datatype='integer' name='[Calculation_1208090660035198979]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR(TODAY())' />
      </column>
      <column caption='zz_rank_an' datatype='integer' name='[Calculation_1215127508971208714]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='INDEX()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Claim Type - TIN' datatype='string' name='[Calculation_1229482703484538880]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='case [claim_type_desc_oi]&#13;&#10;WHEN &apos;A: Prof ASC&apos; then &apos;A&apos;&#13;&#10;WHEN &apos;F: Prof Facility&apos; then &apos;F&apos;&#13;&#10;WHEN &apos;I: IP&apos; then &apos;I&apos;&#13;&#10;WHEN &apos;O: OP Facility&apos; then &apos;O&apos;&#13;&#10;WHEN &apos;P: Prof&apos; then &apos;P&apos;&#13;&#10;WHEN &apos;S: OP ASC&apos; then &apos;S&apos;&#13;&#10;END' />
      </column>
      <column caption='LOB - Claim Type TIN' datatype='string' name='[Calculation_1229482703487901697]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_843017591817953280]+&apos;_&apos;+[Calculation_1229482703484538880]' />
      </column>
      <column caption='Claim Type - State TIN' datatype='string' name='[Calculation_1229482703500111874]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1229482703484538880]+&quot;_&quot;+[final_state]' />
      </column>
      <column caption='Lob - Claim - State TIN' datatype='string' name='[Calculation_1229482703502278659]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1229482703487901697]+&apos;_&apos;+[final_state]' />
      </column>
      <column caption='Payer Count - BM' datatype='string' name='[Calculation_1291688705824231424]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [customer] in [Customer Set] then [payer_short] END' />
      </column>
      <column caption='Annl Agg Savings Flag' datatype='boolean' name='[Calculation_1449033192758759424]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[annl_agg_savings] &gt; 100' />
      </column>
      <column caption='Level of Display ' datatype='string' name='[Calculation_1613977570938392576]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [Parameters].[Parameter 1] = &apos;Customer&apos; then [customer]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &apos;Super Payer Short&apos; then [super_payer_short]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &apos;Payer Short&apos; then [payer_short]&#13;&#10;END' />
      </column>
      <column caption='Disposition Date ' datatype='string' name='[Calculation_211669198996090880]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE MID([disposition_capt_date], 6, 2)&#13;&#10;    WHEN &quot;01&quot; THEN &quot;Jan&quot;&#13;&#10;    WHEN &quot;02&quot; THEN &quot;Feb&quot;&#13;&#10;    WHEN &quot;03&quot; THEN &quot;Mar&quot;&#13;&#10;    WHEN &quot;04&quot; THEN &quot;Apr&quot;&#13;&#10;    WHEN &quot;05&quot; THEN &quot;May&quot;&#13;&#10;    WHEN &quot;06&quot; THEN &quot;Jun&quot;&#13;&#10;    WHEN &quot;07&quot; THEN &quot;Jul&quot;&#13;&#10;    WHEN &quot;08&quot; THEN &quot;Aug&quot;&#13;&#10;    WHEN &quot;09&quot; THEN &quot;Sep&quot;&#13;&#10;    WHEN &quot;10&quot; THEN &quot;Oct&quot;&#13;&#10;    WHEN &quot;11&quot; THEN &quot;Nov&quot;&#13;&#10;    WHEN &quot;12&quot; THEN &quot;Dec&quot;&#13;&#10;END&#13;&#10;+ &quot;-&quot; + LEFT([disposition_capt_date], 4)' />
      </column>
      <column caption='Decision Date ' datatype='string' name='[Calculation_211669198997405698]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE MID([Calculation_892838660606857218], 6, 2)&#13;&#10;    WHEN &quot;01&quot; THEN &quot;Jan&quot;&#13;&#10;    WHEN &quot;02&quot; THEN &quot;Feb&quot;&#13;&#10;    WHEN &quot;03&quot; THEN &quot;Mar&quot;&#13;&#10;    WHEN &quot;04&quot; THEN &quot;Apr&quot;&#13;&#10;    WHEN &quot;05&quot; THEN &quot;May&quot;&#13;&#10;    WHEN &quot;06&quot; THEN &quot;Jun&quot;&#13;&#10;    WHEN &quot;07&quot; THEN &quot;Jul&quot;&#13;&#10;    WHEN &quot;08&quot; THEN &quot;Aug&quot;&#13;&#10;    WHEN &quot;09&quot; THEN &quot;Sep&quot;&#13;&#10;    WHEN &quot;10&quot; THEN &quot;Oct&quot;&#13;&#10;    WHEN &quot;11&quot; THEN &quot;Nov&quot;&#13;&#10;    WHEN &quot;12&quot; THEN &quot;Dec&quot;&#13;&#10;END&#13;&#10;+ &quot;-&quot; + LEFT([Calculation_892838660606857218], 4)' />
      </column>
      <column caption='Product-LOB' datatype='string' name='[Calculation_455708041833984001]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[product_type]+&quot;, &quot;+[Calculation_843017591817953280]' />
      </column>
      <column caption='Market-LOB' datatype='string' name='[Calculation_497366307302117384]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[customer_segment]+&quot;, &quot;+[Calculation_843017591817953280]' />
      </column>
      <column caption='Check List of user' datatype='boolean' name='[Calculation_501588442677899265]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LOWER(USERNAME()) IN [User1 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User2 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User3 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User4 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User5 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User6 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User7 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User8 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User9 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User10 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSE&#13;&#10;FALSE   &#13;&#10;END' />
      </column>
      <column caption='User match' datatype='boolean' name='[Calculation_501588442678079490]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [user1 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE &#13;&#10;ELSEIF [user2 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user3 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user4 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user5 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user6 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user7 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user8 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user9 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user10 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSE FALSE END' />
      </column>
      <column caption='User Flag' datatype='boolean' name='[Calculation_501588442678247427]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_501588442677899265]=TRUE AND [Calculation_501588442678079490]=TRUE&#13;&#10;THEN&#13;&#10;TRUE&#13;&#10;ELSEIF  [Calculation_501588442677899265]=FALSE&#13;&#10;THEN TRUE&#13;&#10;ELSE FALSE&#13;&#10;END' />
      </column>
      <column caption='DP Key' datatype='string' name='[Calculation_545217035210452992]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[dp_key]' />
      </column>
      <column caption='DP Age in Years' datatype='string' name='[Calculation_548313321122136065]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEDIFF(&apos;year&apos;,date([dp_start_date]),TODAY()) &lt;1&#13;&#10;THEN &apos;Less than 1 Year&apos; &#13;&#10;ELSEIF ISNULL(date([dp_start_date]))&#13;&#10;THEN &apos;Custom DP&apos;&#13;&#10;ELSE STR(DATEDIFF(&apos;year&apos;,date([dp_start_date]),TODAY()))&#13;&#10;END' />
      </column>
      <column caption='Solution Filter' datatype='boolean' name='[Calculation_593912267908538368]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [Parameters].[Parameter 13]=&apos;All&apos; THEN [Cv Rule 10 Set All]&#13;&#10;ELSEIF [Parameters].[Parameter 13]=&apos;PPM&apos; THEN [Cv Rule 10 Set PPM]&#13;&#10;ELSEIF [Parameters].[Parameter 13]=&apos;CV&apos; THEN [Cv Rule 10 Set CV] END' />
      </column>
      <column caption='Product-LOB TIN' datatype='string' name='[Calculation_603482407712604162]' role='dimension' type='nominal'>
