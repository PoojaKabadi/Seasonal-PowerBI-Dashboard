                <zone fixed-size='44' h='7522' id='1517' is-fixed='true' is-scaled='1' param='C:/Users/pooja.kabadi/Downloads/test.twb Files/Image/Logo_Internal_CotivitiOI_3.png' type-v2='bitmap' w='9655' x='0' y='0'>
