            <column caption='Dimension for TIN Exposure with State' datatype='string' name='[Dimension for TIN Exposure (copy)_704531922503254016]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;Customer Segment&quot; THEN [final_state]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product Type&quot; THEN [Product Type (copy)_704531922503413761]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues Indicator&quot; THEN [final_state]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;LOB&quot; THEN [LOB-TIN (copy)_704531922504847362]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Claim Type&quot; then [Calculation_1229482703500111874]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product-LOB&quot; THEN [Product-LOB (copy)_704531922505175043]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product-Blues&quot; THEN [Product Type (copy)_704531922503413761]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-LOB&quot; THEN [LOB-TIN (copy)_704531922504847362]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;LOB-Claim&quot; then [Calculation_1229482703502278659]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues-LOB&quot; THEN [LOB-TIN (copy)_704531922504847362]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues-Claim&quot; THEN [Calculation_1229482703500111874]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Blues-LOB&quot; THEN [LOB-TIN (copy)_704531922504847362]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Product-LOB&quot; THEN [Product-LOB (copy)_704531922505175043]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Product-Blues-LOB&quot; THEN [Product-LOB (copy)_704531922505175043]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Claim-LOB&quot; THEN [Calculation_1229482703502278659]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Claim-Blues-LOB&quot; THEN [Calculation_1229482703502278659]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Blues&quot; THEN [final_state]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Overall&quot; THEN [final_state]&#13;&#10;END' />
            </column>
