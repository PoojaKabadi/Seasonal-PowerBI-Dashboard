        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;Customer Segment&quot; THEN &quot;Overall&quot;&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product Type&quot; THEN [product_type]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues Indicator&quot; THEN &quot;Overall&quot;&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;LOB&quot; THEN [Calculation_843017591817953280]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Claim Type&quot; THEN [Calculation_1229482703484538880]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product-LOB&quot; THEN [Calculation_603482407712604162]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product-Blues&quot; THEN [product_type]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-LOB&quot; THEN [Calculation_843017591817953280]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Blues&quot; THEN &quot;Overall&quot;&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;LOB-Claim&quot; THEN [Calculation_1229482703487901697]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues-LOB&quot; THEN [Calculation_843017591817953280]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues-Claim&quot; THEN [Calculation_1229482703484538880]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Blues-LOB&quot; THEN [Calculation_843017591817953280]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Product-LOB&quot; THEN [Calculation_603482407712604162]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Claim-LOB&quot; THEN [Calculation_1229482703487901697]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Product-Blues-LOB&quot; THEN [Calculation_603482407712604162]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Claim-Blues-LOB&quot; THEN [Calculation_1229482703487901697]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Overall&quot; THEN &quot;Overall&quot;&#13;&#10;END' />
      </column>
      <column caption='zz_Calculation1' datatype='integer' name='[Calculation_696650606383464449]' role='measure' type='ordinal'>
