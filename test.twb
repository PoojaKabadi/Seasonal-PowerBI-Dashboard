          <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;Customer Segment&quot; THEN [customer_segment]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product Type&quot; THEN [product_type]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Claim Type&quot; THEN [claim_type_desc_oi]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues Indicator&quot; THEN (IF [blues_indicator]=&apos;Y&apos; then &apos;Blues&apos; ELSEIF [blues_indicator]=&apos;N&apos; then &apos;Non-Blues&apos; END)&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;LOB&quot; THEN [Calculation_843017591817953280]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;LOB-Claim&quot; THEN [Blues-LOB (copy)_1002332437970407424]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product-LOB&quot; THEN [Calculation_455708041833984001]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product-Blues&quot; THEN [Market-Blues (copy)_455708041846730755]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-LOB&quot; THEN [Calculation_497366307302117384]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues-LOB&quot; THEN [Segement/LOB (copy)_497366307307487244]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues-Claim&quot; THEN [Blues-LOB (copy)_1002332437970640897]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Blues-LOB&quot; THEN [Segement/LOB (copy)_497366307307646989]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Product-LOB&quot; THEN [Market-LOB (copy)_455708041852383237] &#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Claim-LOB&quot; THEN [Market-Product-LOB (copy)_1002332437970903042]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Product-Blues-LOB&quot; THEN [Market-Blues-LOB (copy)_455708041861120007]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Claim-Blues-LOB&quot; THEN [Market-Product-Blues-LOB (copy)_1002332437971365891]&#13;&#10;E