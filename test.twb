                  </zone-style>
                </zone>
                <zone fixed-size='44' h='7522' id='1520' is-fixed='true' is-scaled='1' param='C:/Users/pooja.kabadi/Downloads/test.twb Files/Image/06_Feedback icon.png' type-v2='bitmap' url='https://forms.office.com/r/V6PUN1ipB1' w='5266' x='94734' y='0'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
