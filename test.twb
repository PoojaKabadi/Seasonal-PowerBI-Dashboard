            <column caption='Check List of user' datatype='boolean' name='[Calculation_501588442677899265]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF LOWER(USERNAME()) IN [User1 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User2 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User3 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User4 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User5 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User6 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User7 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User8 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User9 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSEIF LOWER(USERNAME()) IN [User10 Live Set]&#13;&#10;THEN TRUE&#13;&#10;ELSE&#13;&#10;FALSE   &#13;&#10;END' />
            </column>
            <column caption='User match' datatype='boolean' name='[Calculation_501588442678079490]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [user1 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE &#13;&#10;ELSEIF [user2 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user3 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user4 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user5 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user6 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user7 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user8 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user9 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSEIF [user10 (oi_ppm_security)]=LOWER(USERNAME()) THEN TRUE&#13;&#10;ELSE FALSE END' />
            </column>
            <column caption='User Flag' datatype='boolean' name='[Calculation_501588442678247427]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_501588442677899265]=TRUE AND [Calculation_501588442678079490]=TRUE&#13;&#10;THEN&#13;&#10;TRUE&#13;&#10;ELSEIF  [Calculation_501588442677899265]=FALSE&#13;&#10;THEN TRUE&#13;&#10;ELSE FALSE&#13;&#10;END' />
            </column>
            <column caption='DP Key' datatype='string' name='[Calculation_545217035210452992]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[dp_key]' />
            </column>
            <column caption='DP Age in Years' datatype='string' name='[Calculation_548313321122136065]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF DATEDIFF(&apos;year&apos;,date([dp_start_date]),TODAY()) &lt;1&#13;&#10;THEN &apos;Less than 1 Year&apos; &#13;&#10;ELSEIF ISNULL(date([dp_start_date]))&#13;&#10;THEN &apos;Custom DP&apos;&#13;&#10;ELSE STR(DATEDIFF(&apos;year&apos;,date([dp_start_date]),TODAY()))&#13;&#10;END' />
            </column>
            <column caption='Solution Filter' datatype='boolean' name='[Calculation_593912267908538368]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF  [Parameters].[Parameter 13]=&apos;All&apos; THEN [Cv Rule 10 Set All]&#13;&#10;ELSEIF [Parameters].[Parameter 13]=&apos;PPM&apos; THEN [Cv Rule 10 Set PPM]&#13;&#10;ELSEIF [Parameters].[Parameter 13]=&apos;CV&apos; THEN [Cv Rule 10 Set CV] END' />
            </column>
            <column caption='Product-LOB TIN' datatype='string' name='[Calculation_603482407712604162]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Product Type (copy)_296674679496093697]+&quot;_&quot;+[product_type]' />
            </column>
            <column caption='Dimension for TIN Exposure' datatype='string' name='[Calculation_630222540141481984]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;Customer Segment&quot; THEN &quot;Overall&quot;&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product Type&quot; THEN [product_type]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues Indicator&quot; THEN &quot;Overall&quot;&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;LOB&quot; THEN [Calculation_843017591817953280]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Claim Type&quot; THEN [Calculation_1229482703484538880]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product-LOB&quot; THEN [Calculation_603482407712604162]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product-Blues&quot; THEN [product_type]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-LOB&quot; THEN [Calculation_843017591817953280]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Blues&quot; THEN &quot;Overall&quot;&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;LOB-Claim&quot; THEN [Calculation_1229482703487901697]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues-LOB&quot; THEN [Calculation_843017591817953280]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues-Claim&quot; THEN [Calculation_1229482703484538880]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Blues-LOB&quot; THEN [Calculation_843017591817953280]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Product-LOB&quot; THEN [Calculation_603482407712604162]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Claim-LOB&quot; THEN [Calculation_1229482703487901697]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Product-Blues-LOB&quot; THEN [Calculation_603482407712604162]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Claim-Blues-LOB&quot; THEN [Calculation_1229482703487901697]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Overall&quot; THEN &quot;Overall&quot;&#13;&#10;END' />
            </column>
            <column caption='zz_Calculation1' datatype='integer' name='[Calculation_696650606383464449]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='RANK_UNIQUE(SUM([annl_agg_savings]), &apos;desc&apos;)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Policy Check' datatype='boolean' name='[Calculation_742530988700868608]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='if [Parameters].[Parameter 12] &lt;&gt; &apos;All Collections/Bundles&apos; then CONTAINS([policy_bundle_indicator], [Parameters].[Parameter 12])&#13;&#10;elseif  [Parameters].[Parameter 12] = &apos;All Collections/Bundles&apos; then TRUE &#13;&#10;END' />
            </column>
            <column caption='Dimension' datatype='string' name='[Calculation_765893448204423168]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;Customer Segment&quot; THEN [customer_segment]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product Type&quot; THEN [product_type]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Claim Type&quot; THEN [claim_type_desc_oi]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues Indicator&quot; THEN (IF [blues_indicator]=&apos;Y&apos; then &apos;Blues&apos; ELSEIF [blues_indicator]=&apos;N&apos; then &apos;Non-Blues&apos; END)&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;LOB&quot; THEN [Calculation_843017591817953280]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;LOB-Claim&quot; THEN [Blues-LOB (copy)_1002332437970407424]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product-LOB&quot; THEN [Calculation_455708041833984001]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Product-Blues&quot; THEN [Market-Blues (copy)_455708041846730755]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-LOB&quot; THEN [Calculation_497366307302117384]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues-LOB&quot; THEN [Segement/LOB (copy)_497366307307487244]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Blues-Claim&quot; THEN [Blues-LOB (copy)_1002332437970640897]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Blues-LOB&quot; THEN [Segement/LOB (copy)_497366307307646989]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Product-LOB&quot; THEN [Market-LOB (copy)_455708041852383237] &#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Claim-LOB&quot; THEN [Market-Product-LOB (copy)_1002332437970903042]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Product-Blues-LOB&quot; THEN [Market-Blues-LOB (copy)_455708041861120007]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Claim-Blues-LOB&quot; THEN [Market-Product-Blues-LOB (copy)_1002332437971365891]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Customer Segment-Blues&quot; THEN [Segment/Blues/LOB (copy)_497366307324567570] &#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Overall&quot; THEN &quot;Overall&quot;&#13;&#10;END' />
            </column>
            <column caption='LOB Description' datatype='string' name='[Calculation_843017591817953280]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='if int([insurance_key])=1 then &apos;Medicare&apos;&#13;&#10;ELSEIF  int([insurance_key])=2 then &apos;Medicaid&apos;&#13;&#10;ELSEIF  int([insurance_key])=3 then &apos;Dual&apos;&#13;&#10;ELSEIF  int([insurance_key])=7 then &apos;Commercial&apos;&#13;&#10;ELSEIF  int([insurance_key])=8 then &apos;Blue Card&apos;&#13;&#10;ELSEIF  int([insurance_key])=9 then &apos;FEP&apos;&#13;&#10;end' />
            </column>
            <column caption='Final CDM Dec Date' datatype='string' name='[Calculation_892838660606857218]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([created_timestamp]) THEN [dec_date]&#13;&#10;ELSEIF REPLACE([dec_date], &quot;-&quot;, &quot;&quot;) &gt; REPLACE([created_timestamp], &quot;-&quot;, &quot;&quot;) THEN [dec_date]&#13;&#10;ELSE [created_timestamp] END' />
            </column>
